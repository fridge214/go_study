// 如果项目使用vendor目录管理依赖，取消下面的注释
// vendor/

// Go编译生成的二进制文件
*.exe
*.exe~
*.dll
*.so
*.dylib

// Go测试生成的二进制文件
*.test

// Go覆盖率工具生成的输出文件
*.out

// 依赖管理工具生成的目录（Go Modules）
go.sum

// IDE和编辑器配置文件
.idea/
.vscode/
*.swp
*.swo
*~

// 操作系统生成的文件
.DS_Store
Thumbs.db

// 日志文件
*.log

// 环境变量配置文件
.env
.env.local

// 构建输出目录
/bin/
/dist/
/build/

// 临时文件
/tmp/
/temp/
